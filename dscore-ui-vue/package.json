{
  "name": "dscore-ui-vue",
  "version": "0.1.0",
  "description": "Vue 3 UI components with style freedom - based on dscore-starter-vue composables",
  "type": "module",
  "main": "./dist/dscore-ui-vue.umd.cjs",
  "module": "./dist/dscore-ui-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/dscore-ui-vue.js",
      "require": "./dist/dscore-ui-vue.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "dscore-starter-vue": "^1.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.7.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "keywords": ["vue", "vue3", "components", "ui", "dscore"],
  "license": "MIT"
}
